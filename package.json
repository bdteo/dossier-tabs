{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@bdteo/dossier-tabs",
  "version": "0.1.0",
  "description": "Tactile, orientation-aware dossier/index tabs for Vue.",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "license": "MIT",
  "author": "Boris D. Teoharov <boristeoharov@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bdteo/dossier-tabs.git"
  },
  "homepage": "https://github.com/bdteo/dossier-tabs#readme",
  "bugs": {
    "url": "https://github.com/bdteo/dossier-tabs/issues"
  },
  "keywords": [
    "vue",
    "tabs",
    "dossier-tabs",
    "index-tabs",
    "shadcn-vue",
    "accessibility",
    "component"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/dossier-tabs.umd.cjs",
  "module": "./dist/dossier-tabs.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/dossier-tabs.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dossier-tabs.js",
      "require": "./dist/dossier-tabs.umd.cjs"
    },
    "./style.css": "./dist/dossier-tabs.css",
    "./source": {
      "types": "./dist/index.d.ts",
      "import": "./src/components/dossier-tabs/index.ts"
    }
  },
  "files": [
    "docs/screenshots",
    "dist",
    "registry",
    "scripts/check-demo-geometry.mjs",
    "scripts/check-demo-screenshots.mjs",
    "scripts/check-package-consumer.mjs",
    "scripts/copy-package-assets.mjs",
    "scripts/capture-demo-screenshots.mjs",
    "scripts/demo-cdp-utils.mjs",
    "scripts/demo-screenshot-utils.mjs",
    "scripts/verify-all.mjs",
    "src/vite-env.d.ts",
    "src/components/dossier-tabs"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "screenshots": "node scripts/capture-demo-screenshots.mjs",
    "verify": "node scripts/verify-all.mjs",
    "verify:demo": "node scripts/check-demo-geometry.mjs",
    "verify:package": "node scripts/check-package-consumer.mjs",
    "verify:screenshots": "node scripts/check-demo-screenshots.mjs",
    "build": "vue-tsc --noEmit && vite build --config vite.lib.config.ts && node scripts/copy-package-assets.mjs",
    "build:demo": "vite build --outDir dist-demo && node scripts/copy-package-assets.mjs dist-demo/assets/assets",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
